/target
**/*.rs.bk
*.pdb

# IDE / OS
.idea/
.vscode/
.DS_Store

# Local env / overrides
.env
.env.local
.cargo/.config.toml.local

# Build artifacts pulled out of Docker
/dist

# Working notes / scratch plans (per-feature, not committed)
/.plans/

# Synced emoji assets (downloaded via scripts/sync-emoji.sh; manifest is the source of truth)
/assets/fluent/*
!/assets/fluent/manifest.toml

# Tauri sidecar staging — `just package` copies the release daemon
# here as `gobcam-pipeline-<target-triple>`. Always rebuilt from
# target/release/, never source-of-truth.
/crates/ui/src-tauri/binaries/
