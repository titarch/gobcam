#!/bin/sh
# postinst — runs as root from `apt install gobcam`.
#
# /etc/modules-load.d/gobcam.conf and /etc/modprobe.d/gobcam.conf are
# already on disk by the time we get here (shipped as bundle files).
# This script:
#   1. Tries `modprobe v4l2loopback` so /dev/video10 is available now,
#      not only after a reboot. Best-effort — if DKMS hasn't finished
#      building (or the kernel headers are missing on a brand-new
#      host) modules-load.d catches it on the next boot.
#   2. Drops a narrow sudoers rule so the installing user can reset
#      the v4l2loopback module without a password prompt — the UI's
#      auto-reset path uses this when a mode switch finds the loopback
#      locked.
#   3. Refreshes the GTK icon cache + desktop database (conventional
#      Debian post-install hygiene).

set -e

VIDEO_NR=10
CARD_LABEL=Gobcam
SUDOERS=/etc/sudoers.d/gobcam

case "$1" in
    configure)
        # 1. Best-effort modprobe.
        if modprobe v4l2loopback 2>/dev/null; then
            echo "[gobcam] loaded v4l2loopback now (/dev/video${VIDEO_NR})."
        else
            echo "[gobcam] could not modprobe v4l2loopback (DKMS may still"
            echo "         be building). It will load on the next boot." >&2
        fi

        # 2. Narrow sudoers rule for the installing user. apt/dpkg sets
        #    SUDO_USER when the install came in via `sudo apt install …`;
        #    if it's empty (root login) leave a hint and skip.
        target_user=""
        if [ -n "${SUDO_USER:-}" ] && [ "${SUDO_USER}" != "root" ]; then
            target_user="$SUDO_USER"
        elif [ -n "${PKEXEC_UID:-}" ]; then
            target_user=$(getent passwd "$PKEXEC_UID" | cut -d: -f1 || true)
        fi
        if [ -n "$target_user" ] && [ "$target_user" != "root" ]; then
            rmmod_path=$(command -v rmmod || echo /usr/bin/rmmod)
            modprobe_path=$(command -v modprobe || echo /usr/bin/modprobe)
            cat > "$SUDOERS" <<EOF
# Generated by gobcam .deb postinst. Allows $target_user to reset the
# v4l2loopback module without a password prompt — required for the
# UI's auto-reset path on mode changes.
$target_user ALL=(root) NOPASSWD: $rmmod_path v4l2loopback
$target_user ALL=(root) NOPASSWD: $modprobe_path v4l2loopback devices=1 video_nr=${VIDEO_NR} card_label=${CARD_LABEL} exclusive_caps=1
EOF
            chmod 0440 "$SUDOERS"
            if visudo -c -q -f "$SUDOERS" 2>/dev/null; then
                echo "[gobcam] installed sudoers rule for $target_user."
            else
                rm -f "$SUDOERS"
                echo "[gobcam] sudoers rule failed visudo validation; removed." >&2
            fi
        else
            echo "[gobcam] could not detect the installing user; skipping"
            echo "         sudoers rule. Run \`sudo gobcam-setup\` from your"
            echo "         normal account if you want auto-reset on mode changes." >&2
        fi

        # 3. Conventional Debian post-install hygiene.
        if command -v update-desktop-database >/dev/null 2>&1; then
            update-desktop-database -q || true
        fi
        if command -v gtk-update-icon-cache >/dev/null 2>&1; then
            gtk-update-icon-cache -q -t /usr/share/icons/hicolor || true
        fi
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
esac

exit 0
