#!/usr/bin/env bash
# gobcam-setup — one-time installer for the v4l2loopback module.
#
# Drops two snippets under /etc so the kernel loads v4l2loopback at
# every boot with the options Gobcam wants:
#
#   /etc/modules-load.d/gobcam.conf  (asks systemd to load it)
#   /etc/modprobe.d/gobcam.conf      (sets video_nr, card_label, etc.)
#
# After running this once, `/dev/video10` is available on every boot
# with no further sudo prompts. The Gobcam UI/daemon launch unattended.
#
# Usage:
#   sudo  bash scripts/gobcam-setup           # plain sudo
#   pkexec bash scripts/gobcam-setup           # graphical prompt
#   pkexec bash scripts/gobcam-setup --uninstall
#
# Idempotent — running it twice is safe; running with --uninstall
# removes the snippets and rmmod's the module.

set -euo pipefail

MODULES_LOAD=/etc/modules-load.d/gobcam.conf
MODPROBE_OPTS=/etc/modprobe.d/gobcam.conf
SUDOERS=/etc/sudoers.d/gobcam

VIDEO_NR=10
CARD_LABEL="Gobcam"

uninstall=0
if [ "${1:-}" = "--uninstall" ]; then
    uninstall=1
fi

# ────────────────────────────────────────────────────────────────────
# Self-elevate: if not root, re-exec under pkexec (graphical prompt)
# or fail with a clear hint. Resolve `$0` to an absolute path first
# because pkexec resets cwd to the target user's home (`/root`),
# breaking any relative invocation like `bash ./scripts/gobcam-setup`.
# ────────────────────────────────────────────────────────────────────
if [ "$(id -u)" -ne 0 ]; then
    SELF=$(realpath -- "$0")
    if command -v pkexec >/dev/null 2>&1; then
        exec pkexec --disable-internal-agent bash "$SELF" "$@"
    fi
    echo "gobcam-setup must run as root. Try:" >&2
    echo "    sudo bash $SELF $*" >&2
    exit 1
fi

if [ "$uninstall" -eq 1 ]; then
    echo "[gobcam-setup] uninstalling…"
    rm -f "$MODULES_LOAD" "$MODPROBE_OPTS" "$SUDOERS"
    echo "  removed $MODULES_LOAD"
    echo "  removed $MODPROBE_OPTS"
    echo "  removed $SUDOERS"
    if lsmod | grep -q '^v4l2loopback'; then
        if rmmod v4l2loopback; then
            echo "  unloaded v4l2loopback"
        else
            echo "  v4l2loopback in use; will be gone after next reboot." >&2
        fi
    fi
    echo "[gobcam-setup] done. Reboot to ensure /dev/video10 is gone for good."
    exit 0
fi

echo "[gobcam-setup] installing…"

cat > "$MODULES_LOAD" <<EOF
# Auto-load v4l2loopback at boot for Gobcam.
v4l2loopback
EOF
echo "  wrote $MODULES_LOAD"

cat > "$MODPROBE_OPTS" <<EOF
# Gobcam: allocate one loopback at /dev/video${VIDEO_NR} with
# exclusive_caps so Chromium-based apps (Teams, Meet) discover it as
# a webcam. Generated by scripts/gobcam-setup.
options v4l2loopback devices=1 video_nr=${VIDEO_NR} card_label="${CARD_LABEL}" exclusive_caps=1
EOF
echo "  wrote $MODPROBE_OPTS"

# Try loading immediately so the user doesn't need to reboot. If the
# module is already loaded with different options we leave it alone —
# next reboot picks up the new options.
if lsmod | grep -q '^v4l2loopback'; then
    echo "  v4l2loopback already loaded (current options will persist until reboot)."
elif modprobe v4l2loopback; then
    echo "  loaded v4l2loopback now"
else
    echo "  config in place, but loading now failed (possibly DKMS not built)." >&2
    echo "  /dev/video${VIDEO_NR} will be ready after the next reboot." >&2
fi

# ────────────────────────────────────────────────────────────────────
# sudoers drop-in: lets the invoking user reset v4l2loopback without
# a password prompt. Used by the UI's auto-reset path when a mode
# change finds the loopback locked. Grants are narrow — exact-arg
# matches for `rmmod v4l2loopback` and the canonical `modprobe`
# invocation only.
# ────────────────────────────────────────────────────────────────────
target_user=""
if [ -n "${PKEXEC_UID:-}" ]; then
    target_user=$(getent passwd "$PKEXEC_UID" | cut -d: -f1 || true)
elif [ -n "${SUDO_USER:-}" ]; then
    target_user="$SUDO_USER"
fi

if [ -z "$target_user" ] || [ "$target_user" = "root" ]; then
    echo "  (skipping sudoers — could not determine invoking user; run via" >&2
    echo "   pkexec or sudo from your normal account if you want auto-reset)" >&2
else
    rmmod_path=$(command -v rmmod || echo /usr/bin/rmmod)
    modprobe_path=$(command -v modprobe || echo /usr/bin/modprobe)
    cat > "$SUDOERS" <<EOF
# Generated by scripts/gobcam-setup. Allows $target_user to reset
# the v4l2loopback module without a password prompt — required for
# the UI's auto-reset path on mode changes.
$target_user ALL=(root) NOPASSWD: $rmmod_path v4l2loopback
$target_user ALL=(root) NOPASSWD: $modprobe_path v4l2loopback devices=1 video_nr=${VIDEO_NR} card_label=${CARD_LABEL} exclusive_caps=1
EOF
    chmod 0440 "$SUDOERS"
    if visudo -c -q -f "$SUDOERS"; then
        echo "  wrote $SUDOERS for user $target_user"
    else
        echo "  $SUDOERS failed visudo validation; removing." >&2
        rm -f "$SUDOERS"
    fi
fi

echo
echo "[gobcam-setup] done. /dev/video${VIDEO_NR} will be available on every boot."
echo "    Uninstall with: sudo bash $0 --uninstall"
