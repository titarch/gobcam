# Gobcam developer convenience: passwordless reset of the v4l2loopback module.
#
# Install (one-time, requires root):
#   sudo install -m 0440 -o root -g root \
#       scripts/sudoers-gobcam-dev /etc/sudoers.d/gobcam-dev
#   sudo visudo -c -f /etc/sudoers.d/gobcam-dev   # validate
#
# Uninstall:
#   sudo rm /etc/sudoers.d/gobcam-dev
#
# Replace `bparsy` with your own username if you fork this.
#
# Security note: this only grants exact-argument matches. Any deviation
# (different flags, different module name) falls back to a normal sudo
# prompt. The same user can already run these with a password — this just
# removes the prompt.

bparsy ALL=(root) NOPASSWD: /usr/bin/rmmod v4l2loopback
bparsy ALL=(root) NOPASSWD: /usr/bin/modprobe v4l2loopback devices=1 video_nr=10 card_label=Gobcam exclusive_caps=1
