{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gobcam",
  "version": "0.0.1",
  "identifier": "io.gobcam.ui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Gobcam",
        "width": 360,
        "height": 640,
        "minWidth": 320,
        "minHeight": 400,
        "alwaysOnTop": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$CACHE/gobcam/**"]
      }
    }
  },
  "bundle": {
    "active": false
  }
}
